# PostgreSQL database URL (required)
# For local dev: postgresql://user:password@localhost:5432/sitedoc
# For Neon/Supabase: use the connection string they provide
DATABASE_URL="postgresql://user:password@localhost:5432/sitedoc"

NEXTAUTH_SECRET="generate-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Twilio SMS alerts
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Monitoring cron secret
CRON_SECRET="generate-a-random-secret"
